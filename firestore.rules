rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getMembershipData(boxId) {
      let path = /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + boxId);
      return get(path).data;
    }
    
    function isActiveMember(boxId) {
      let path = /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + boxId);
      return isAuthenticated() && 
             exists(path) &&
             get(path).data.status == 'active';
    }
    
    function hasRole(boxId, roles) {
      return isActiveMember(boxId) && 
             getMembershipData(boxId).role in roles;
    }

    // --- Rules ---

    // User Profile and Personal Data (Workouts, Schedule, etc.)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Explicit access to sub-collections for better query compatibility
      match /workouts/{id} { allow read, write: if isOwner(userId); }
      match /schedule/{id} { allow read, write: if isOwner(userId); }
      match /exercises/{id} { allow read, write: if isOwner(userId); }
      match /records/{id} { allow read, write: if isOwner(userId); }

      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /boxes/{boxId} {
      // Basic box info should be readable by any authenticated user for discovery
      allow read: if isAuthenticated();
      allow write: if hasRole(boxId, ['administrator']);
      
      // Performance data
      match /performance_data/{athleteId} {
        allow read: if hasRole(boxId, ['coach', 'administrator']) || 
                      (isActiveMember(boxId) && request.auth.uid == athleteId);
        allow write: if isOwner(athleteId) || hasRole(boxId, ['coach', 'administrator']);
      }
      
      match /financial_data/{userId} {
        allow read: if hasRole(boxId, ['administrative', 'administrator']);
        allow create, update, delete: if hasRole(boxId, ['administrator']);
      }

      match /schedule/{itemId} {
        // Allow any authenticated user to see the schedule
        allow read: if isAuthenticated();
        allow write: if hasRole(boxId, ['coach', 'administrative', 'administrator']);
      }
    }

    match /memberships/{membershipId} {
      // Users can read their own memberships, admins can read all for their box
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        membershipId.matches('^' + request.auth.uid + '.*') ||
        hasRole(resource.data.boxId, ['administrative', 'administrator'])
      );
      allow write: if false; 
    }

    match /invites/{inviteId} {
      allow read: if isAuthenticated() && (
        hasRole(resource.data.boxId, ['administrative', 'administrator']) ||
        (resource.data.inviteeUserId != null && request.auth.uid == resource.data.inviteeUserId) ||
        (resource.data.email != null && request.auth.token.email == resource.data.email)
      );

      allow create: if hasRole(request.resource.data.boxId, ['administrator']);
      allow delete, update: if hasRole(resource.data.boxId, ['administrator']);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
